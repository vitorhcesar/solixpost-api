# Server
PORT=8080
NODE_ENV=development

# ─── Produção (solixpost.com.br) ─────────────────────────────────────────────
# Frontend: https://app.solixpost.com.br
# API:      https://api.solixpost.com.br
# CORS_ORIGIN=https://app.solixpost.com.br
# BETTER_AUTH_URL=https://api.solixpost.com.br
# PUBLIC_API_URL=https://api.solixpost.com.br
# INSTAGRAM_REDIRECT_URI=https://api.solixpost.com.br/api/v1/instagram/connect/callback
# SMTP_FROM=noreply@solixpost.com.br
# Webhook OmegaPay: https://api.solixpost.com.br/api/v1/webhooks/omegapay

# Database (docker-compose: solixpost-postgres na porta 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/solixpost?schema=public

# Better Auth
# Gere um secret com: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=http://localhost:8080

# CORS (origem do frontend)
CORS_ORIGIN=http://localhost:5173

# Instagram / Meta (Business Login for Instagram)
# App ID e Secret em: Meta App Dashboard > Instagram > API setup with Instagram login
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8080/api/v1/instagram/connect/callback
# Meta App Dashboard (Settings > Basic / Business login settings):
#   Privacy Policy URL:          https://app.solixpost.com.br/privacy
#   Terms of Service URL:        https://app.solixpost.com.br/terms
#   User Data Deletion (instr.): https://app.solixpost.com.br/data-deletion
#   User Data Deletion (API):    https://api.solixpost.com.br/api/v1/instagram/data-deletion
#   OAuth Redirect URI:          https://api.solixpost.com.br/api/v1/instagram/connect/callback
#   Deauthorize callback URL:    https://api.solixpost.com.br/api/v1/instagram/deauthorize
INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_content_publish

# Opcional: chave dedicada para criptografar tokens (fallback: BETTER_AUTH_SECRET)
# INSTAGRAM_TOKEN_ENCRYPTION_KEY=

# URL pública da API (usada para montar o link da mídia enviado ao Instagram)
# Em dev: use o mesmo domínio ngrok configurado no INSTAGRAM_REDIRECT_URI
PUBLIC_API_URL=http://localhost:8080

# MinIO (object storage temporário de mídias)
# docker-compose: solixpost-minio nas portas 9000 (API) e 9001 (console)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=solixpost-temp
MINIO_USE_SSL=false

# Redis (BullMQ)
# docker-compose: solixpost-redis na porta 6379
REDIS_HOST=localhost
REDIS_PORT=6379

# OmegaPay
# Credenciais em: painel OmegaPay > Integrações > API
OMEGAPAY_PUBLIC_KEY=
OMEGAPAY_SECRET_KEY=
# URL de webhook para callbackUrl / painel: {PUBLIC_API_URL}/api/v1/webhooks/omegapay

# SMTP
SMTP_HOST=smtp.smtp.com
SMTP_PORT=465
SMTP_USERNAME=email@email.com
SMTP_PASSWORD="smtp_password"
SMTP_FROM=email@email.com
SMTP_SECURE=true # true para SSL/TLS, false para STARTTLS
