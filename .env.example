# Server
PORT=8080
NODE_ENV=development

# Database (docker-compose: instagram-posts-auto-postgres na porta 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/instagram_posts_auto?schema=public

# Better Auth
# Gere um secret com: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=http://localhost:8080

# CORS (origem do frontend)
CORS_ORIGIN=http://localhost:5173

# Instagram / Meta (Business Login for Instagram)
# App ID e Secret em: Meta App Dashboard > Instagram > API setup with Instagram login
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8080/api/v1/instagram/connect/callback
INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_content_publish

# Opcional: chave dedicada para criptografar tokens (fallback: BETTER_AUTH_SECRET)
# INSTAGRAM_TOKEN_ENCRYPTION_KEY=
